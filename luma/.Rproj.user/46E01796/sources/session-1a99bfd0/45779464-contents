library(luma)

# Toy "light curve": sinusoidal oscillation with noise
set.seed(42)
t <- seq(0, 2*pi, length.out = 200)
f <- sin(t) + 0.1 * rnorm(length(t))

path <- data.frame(t = t, f = f)

# Quick visualization
plot(path[,1], path[,2], type="l", col="blue", lwd=2,
     xlab="Time", ylab="Flux", main="Toy Light Curve (sinusoid)")

# Now compute scalar log-signature features
drift_f(path)    # net change in flux
levy_tf(as.matrix(path))    # area term
curl_t(path)     # "weighted area" in time direction
curl_f(path)     # "weighted area" in flux direction
jerk_t(path)     # higher-order change along time
twist_tf(path)   # interaction term
jerk_f(path)     # higher-order change along flux

sig_features(as.matrix(path),depth=3)



